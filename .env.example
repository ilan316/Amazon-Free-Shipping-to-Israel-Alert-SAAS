# Copy this file to .env and fill in the values
# NEVER commit .env to git

# ── Database (auto-provided by Railway PostgreSQL plugin) ──────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── JWT Authentication ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=replace-with-64-char-random-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ── Gmail SMTP ─────────────────────────────────────────────────────────────────
# Sender Gmail address
GMAIL_SENDER=amazonisraelalert@gmail.com
# Gmail App Password (16 chars, spaces OK)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Scheduler ─────────────────────────────────────────────────────────────────
CHECK_INTERVAL_MINUTES=120
NOTIFICATION_COOLDOWN_HOURS=24

# ── Amazon Affiliate (optional) ────────────────────────────────────────────────
AMAZON_AFFILIATE_TAG=amzfreeil-20

# ── Logo URL for emails (optional — uses external URL for better deliverability)
LOGO_URL=https://app.amzfreeil.com/static/logo-new.png

# ── Admin API protection ───────────────────────────────────────────────────────
ADMIN_SECRET_TOKEN=replace-with-random-string

# ── Playwright browser profile directory ──────────────────────────────────────
BROWSER_PROFILE_DIR=/app/browser_profile
